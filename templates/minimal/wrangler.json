{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "beam-app",
  "main": "./dist/index.js",
  "compatibility_date": "2024-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist"
  },
  "build": {
    "command": "npx --no-install beam build --dev",
    "watch_dir": "app"
  },
  "vars": {
    "SESSION_SECRET": "dev-secret-change-in-production"
  }
}
